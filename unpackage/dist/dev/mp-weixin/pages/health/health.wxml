<view class="health-page data-v-7cd1e374"><view class="status-bar data-v-7cd1e374"></view><view class="header klein-blue data-v-7cd1e374"><text class="page-title white-text data-v-7cd1e374">健康管理</text></view><view class="summary-cards data-v-7cd1e374"><view class="card data-v-7cd1e374"><text class="label data-v-7cd1e374">今日步数</text><text class="value data-v-7cd1e374">{{stepCount+''}}<text class="unit data-v-7cd1e374">步</text></text><view class="progress-bg data-v-7cd1e374"><view class="progress data-v-7cd1e374" style="{{'width:'+(stepProgress+'%')+';'}}"></view></view><text class="goal data-v-7cd1e374">目标：8000 步</text></view><view class="card data-v-7cd1e374"><text class="label data-v-7cd1e374">睡眠时长</text><text class="value data-v-7cd1e374">{{sleepHours}}<text class="unit data-v-7cd1e374">h</text></text><view class="progress-bg data-v-7cd1e374"><view class="progress sleep data-v-7cd1e374" style="{{'width:'+(sleepProgress+'%')+';'}}"></view></view><text class="goal data-v-7cd1e374">建议：7-9 小时</text></view></view><view class="section-title data-v-7cd1e374"> 近3日步数</view><view class="history-list data-v-7cd1e374"><block wx:for="{{historyData}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="history-item data-v-7cd1e374"><text class="data-v-7cd1e374">{{item.date}}</text><text class="history-value data-v-7cd1e374">{{item.steps+" 步"}}</text></view></block></view><view class="section-title data-v-7cd1e374"> 健康建议</view><view class="advice-list data-v-7cd1e374"><block wx:for="{{adviceList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="advice-item data-v-7cd1e374"><u-icon vue-id="{{'714b3b80-1-'+index}}" name="order" color="#002F6C" size="36" class="data-v-7cd1e374" bind:__l="__l"></u-icon><text class="advice-text data-v-7cd1e374">{{item}}</text></view></block></view><view class="footer-space data-v-7cd1e374"></view></view>