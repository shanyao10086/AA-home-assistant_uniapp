<view class="root"><view class="navBarBox"><view class="statusBar" style="{{'padding-top:'+(statusBarHeight+'px')+';'}}"></view><view class="navBar"><view class="navBarTitle"> 个人中心 </view></view></view><view class="header"><view class="filterGray"><block wx:if="{{isLogin}}"><view class="userInfo"><image class="userAvatar" src="/static/avatar/def.png" data-event-opts="{{[['tap',[['updataAvatar']]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['changeName']]]]}}" class="userName" bindtap="__e"><text>{{userInfo.username||userInfo.nickName||'用户'}}</text></view></view></block><block wx:else><view data-event-opts="{{[['tap',[['triggerAutoLogin']]]]}}" class="userInfo" bindtap="__e"><image class="userAvatar" src="/static/avatar/def.png"></image><view class="userName"><text class="login-text">点击登录</text></view></view></block></view></view><view class="funcList"><view class="funcItem"><text>饮食记录</text></view><view data-event-opts="{{[['tap',[['toSport']]]]}}" class="funcItem" bindtap="__e"><text>运动记录</text></view><view class="funcItem"><text>健康周报</text></view><view data-event-opts="{{[['tap',[['toSettings']]]]}}" class="funcItem" bindtap="__e"><text>设置</text></view><view data-event-opts="{{[['tap',[['toAbout']]]]}}" class="funcItem" bindtap="__e"><text>关于</text></view></view><view class="footer-space"></view></view>