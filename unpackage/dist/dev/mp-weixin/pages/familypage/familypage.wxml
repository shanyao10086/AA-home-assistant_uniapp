<view class="root"><view class="navBarBox"><view class="statusBar" style="{{'padding-top:'+(statusBarHeight+'px')+';'}}"></view><view class="navBar"><view style="color:#FBF2E3;font-size:36rpx;font-weight:500;"> 家庭中心 </view></view></view><view class="content"><view class="topContainer card-border"><block wx:if="{{!Today}}"><view class="dateCard"><view>获取日期失败</view></view></block><block wx:else><view class="dateCard"><view class="date">{{Today.date}}</view><view class="day-of-week">{{Today.dayOfWeek}}</view><view class="year">{{Today.year}}</view><view class="month">{{Today.month+"月"}}</view></view></block><view class="listCard"><view class="listTitle">今日待办</view><block wx:for="{{todoList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="listItem"><view class="itemContent">{{item.content}}</view></view></block></view></view><scroll-view class="messageBoard card-border"><view class="messageTitle">留言板</view><block wx:for="{{messageList}}" wx:for-item="item" wx:for-index="__i1__" wx:key="id"><view class="messageItem"><view class="messageContent">{{item.content}}</view><view class="messageInfo"><view class="messageTime">{{item.time}}</view><view class="messageFrom">{{"from "+item.from}}</view></view></view></block></scroll-view><view class="big-button"><button data-event-opts="{{[['tap',[['testJwtConnection']]]]}}" bindtap="__e">jwt测试</button></view></view></view>